# --- Core ---
# Supabase PostgreSQL connection string
# Find this in: Supabase Dashboard → Project → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
REMINDER_INTERVAL_MINUTES=15

# --- Meta shared ---
META_VERIFY_TOKEN=choose-any-string-and-match-it-in-meta-dashboard

# --- Instagram Messaging API (lead capture) ---
INSTAGRAM_ACCESS_TOKEN=

# --- WhatsApp Cloud API (owner reminders) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OWNER_NUMBER=
# Template must be approved in Meta Business Manager with 2 body vars: {{1}}=brand name, {{2}}=hours
WHATSAPP_TEMPLATE_NAME=lead_reminder

# --- Lead keyword filter (comma-separated, used by Instagram ingest) ---
LEAD_KEYWORDS=book,booking,shoot,photography,food shoot,rate,rates,price,pricing,available,availability,hire,quote,inquiry,package,how much,cost,interested,collaboration,project
