# --- Core ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
REMINDER_INTERVAL_MINUTES=15

# --- Meta shared ---
META_VERIFY_TOKEN=choose-a-random-secret-string
META_APP_SECRET=your-meta-app-secret                 # from Meta App Dashboard → App Secret

# --- Instagram Messaging API (lead capture) ---
INSTAGRAM_ACCESS_TOKEN=

# --- Telegram Bot (owner reminders) ---
# 1. Create bot via @BotFather on Telegram → get BOT_TOKEN
# 2. Client sends any message to the bot → call getUpdates to get CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- App authentication ---
# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=generate-a-long-random-string-here
APP_USERNAME=your-username
APP_PASSWORD=your-strong-password

# --- Security ---
SESSION_HTTPS_ONLY=false   # set to true in production (behind HTTPS)
ENABLE_DOCS=false          # set to true temporarily to access /docs
MAX_BODY_SIZE_MB=1

# --- Lead keyword filter (comma-separated) ---
LEAD_KEYWORDS=book,booking,shoot,photography,photographer,videographer,videography,food shoot,rate,rates,price,pricing,charges,costing,available,availability,hire,quote,inquiry,package,packages,how much,cost,interested,collaboration,collaborations,project,portfolio,reel,reels,budget
